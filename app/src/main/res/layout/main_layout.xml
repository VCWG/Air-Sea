<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#CC222222"
    android:paddingLeft="8dp"
    android:paddingRight="8dp"
    android:paddingTop="2dp"
    android:paddingBottom="8dp">

    <!-- Left Column: Scrollable tracking sections + status + sync button -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginRight="4dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Scrollable section containing Maritime and Air tracking controls -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"
            android:fadeScrollbars="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ═══════════ MARITIME TRACKING ═══════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <CheckBox
                        android:id="@+id/maritime_enable_checkbox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:button="@drawable/checkbox_enable_selector"
                        android:saveEnabled="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:text="MARITIME"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Maritime collapsible content -->
                <LinearLayout
                    android:id="@+id/maritime_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data Source"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1">

                            <Spinner
                                android:id="@+id/data_source_spinner"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:spinnerMode="dropdown"
                                android:dropDownWidth="wrap_content"
                                android:paddingLeft="0dp"
                                android:paddingRight="0dp"
                                android:background="@drawable/spinner_bg" />

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="6dp"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_spinner_arrow"
                                android:clickable="false"
                                android:focusable="false" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/data_source_tooltip"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginLeft="8dp"
                            android:background="@drawable/tooltip_circle"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="?"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Hidden when USB RTL-SDR is selected as maritime source -->
                    <LinearLayout
                        android:id="@+id/maritime_apikey_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="API Key"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/api_key_display"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:layout_marginTop="1dp"
                            android:background="?android:attr/editTextBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:hint="Tap to enter API key"
                            android:paddingLeft="8dp"
                            android:paddingRight="8dp"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/broadcast_all_checkbox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="0dp"
                        android:text="Broadcast All"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:buttonTint="#4A90D9"
                        android:saveEnabled="false" />

                    <CheckBox
                        android:id="@+id/maritime_military_only_checkbox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="0dp"
                        android:text="Military Only"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:buttonTint="#4A90D9"
                        android:saveEnabled="false" />

                </LinearLayout>

                <!-- Divider between sections -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="6dp"
                    android:background="#666666" />

                <!-- ═══════════ AIR TRAFFIC ═══════════ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <CheckBox
                        android:id="@+id/air_enable_checkbox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:button="@drawable/checkbox_enable_selector"
                        android:saveEnabled="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:text="AIR TRAFFIC"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Air collapsible content -->
                <LinearLayout
                    android:id="@+id/air_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Data Source"
                        android:textColor="@color/white"
                        android:textSize="14sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <FrameLayout
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1">

                            <Spinner
                                android:id="@+id/air_data_source_spinner"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:spinnerMode="dropdown"
                                android:dropDownWidth="wrap_content"
                                android:paddingLeft="0dp"
                                android:paddingRight="0dp"
                                android:background="@drawable/spinner_bg" />

                            <ImageView
                                android:layout_width="10dp"
                                android:layout_height="6dp"
                                android:layout_gravity="end|center_vertical"
                                android:layout_marginEnd="6dp"
                                android:src="@drawable/ic_spinner_arrow"
                                android:clickable="false"
                                android:focusable="false" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/air_data_source_tooltip"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center_vertical"
                            android:layout_marginLeft="8dp"
                            android:background="@drawable/tooltip_circle"
                            android:gravity="center"
                            android:includeFontPadding="false"
                            android:text="?"
                            android:textColor="#000000"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true" />

                    </LinearLayout>

                    <!-- Shown for adsb.fi / airplanes.live / adsb.lol -->
                    <LinearLayout
                        android:id="@+id/air_apikey_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="API Key"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/air_api_key_display"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:layout_marginTop="1dp"
                            android:background="?android:attr/editTextBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:hint="Not required"
                            android:paddingLeft="8dp"
                            android:paddingRight="8dp"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <!-- Shown only when OpenSky is selected -->
                    <LinearLayout
                        android:id="@+id/opensky_credentials_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Client ID"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/opensky_client_id_display"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:layout_marginTop="1dp"
                            android:background="?android:attr/editTextBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:hint="Optional (higher limits)"
                            android:paddingLeft="8dp"
                            android:paddingRight="8dp"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Client Secret"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/opensky_client_secret_display"
                            android:layout_width="match_parent"
                            android:layout_height="42dp"
                            android:layout_marginTop="1dp"
                            android:background="?android:attr/editTextBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:hint="Optional (higher limits)"
                            android:paddingLeft="8dp"
                            android:paddingRight="8dp"
                            android:textColor="@color/white"
                            android:textSize="14sp" />

                    </LinearLayout>

                    <CheckBox
                        android:id="@+id/air_broadcast_all_checkbox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="0dp"
                        android:text="Broadcast All"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:buttonTint="#4A90D9"
                        android:saveEnabled="false" />

                    <CheckBox
                        android:id="@+id/air_military_only_checkbox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="0dp"
                        android:text="Military Only"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:buttonTint="#4A90D9"
                        android:saveEnabled="false" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Status lines fixed above the sync button -->
        <TextView
            android:id="@+id/maritime_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="2dp"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/air_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/sync_btn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#555555"
            android:text="@string/start_sync"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#444444" />

    <!-- Right Column: Bounding Box, Frequency -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_marginLeft="4dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:fadeScrollbars="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Coverage Area"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Latitude Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="4dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Min Lat"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/min_lat_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="-90.0"
                    android:inputType="numberDecimal|numberSigned"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Max Lat"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/max_lat_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="90.0"
                    android:inputType="numberDecimal|numberSigned"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Longitude Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="4dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Min Lon"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/min_lon_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="-180.0"
                    android:inputType="numberDecimal|numberSigned"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Max Lon"
                    android:textColor="@color/white"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/max_lon_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="180.0"
                    android:inputType="numberDecimal|numberSigned"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/use_map_view_btn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="#555555"
            android:text="USE CURRENT\nMAP VIEW"
            android:textAllCaps="true"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#444444" />

        <!-- Shown only when USB RTL-SDR is selected for maritime or air -->
        <LinearLayout
            android:id="@+id/rtl_tcp_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RTL-SDR Driver Port"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/rtl_port_tooltip"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginLeft="6dp"
                    android:background="@drawable/tooltip_circle"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="?"
                    android:textColor="#000000"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/rtl_tcp_port_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="1234"
                    android:inputType="number"
                    android:singleLine="true"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/rtl_tcp_auto_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginLeft="4dp"
                    android:background="#555555"
                    android:text="START"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:background="#444444" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="API Update Rate"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:layout_marginTop="4dp">

            <Spinner
                android:id="@+id/frequency_spinner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:spinnerMode="dropdown"
                android:dropDownWidth="wrap_content"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:background="@drawable/spinner_bg" />

            <ImageView
                android:layout_width="10dp"
                android:layout_height="6dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_spinner_arrow"
                android:clickable="false"
                android:focusable="false" />

        </FrameLayout>

    </LinearLayout>

    </ScrollView>

</LinearLayout>
